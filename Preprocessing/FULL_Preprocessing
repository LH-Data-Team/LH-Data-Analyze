        "work_ev": "work_ev_mean",
        "work_night": "work_night_mean",
    })
    return z05

z05 = build_05_chunked("05._시간대별_직장인구.csv", grid_slim, chunksize=100_000)
cols05 = ["work_total_mean", "work_am_mean", "work_pm_mean", "work_ev_mean", "work_night_mean"]
grid_master = grid_master.drop(columns=cols05, errors="ignore").merge(z05[["gid"] + cols05], on="gid", how="left")
# NaN 유지


# =========================
# 4) (아동 CSV) + 3) (03 거주인구 20~50/60+ + masked) -> 맨 뒤에 붙이기
# =========================
df_child = pd.read_csv("sgis_grid_child_pop.csv")
df_child = df_child[["gid", "pop"]].copy()
df_child["gid"] = df_child["gid"].astype(str).str.strip()
df_child["pop"] = pd.to_numeric(df_child["pop"], errors="coerce")
z_child = df_child.groupby("gid", as_index=False).agg(child0_15_total=("pop", "sum"))

df03 = pd.read_csv("03._성연령별_거주인구(격자).csv")
adult_groups = [
    ("m_20g_pop","w_20g_pop"),
    ("m_30g_pop","w_30g_pop"),
    ("m_40g_pop","w_40g_pop"),
    ("m_50g_pop","w_50g_pop"),
]
senior_groups = [
    ("m_60g_pop","w_60g_pop"),
    ("m_70g_pop","w_70g_pop"),
    ("m_80g_pop","w_80g_pop"),
    ("m_90g_pop","w_90g_pop"),
    ("m_100g_pop","w_100g_pop"),
]
need = ["gid"] + [c for pair in (adult_groups + senior_groups) for c in pair]
df03 = df03[need].copy()
for c in need:
    if c != "gid":
        df03[c] = pd.to_numeric(df03[c], errors="coerce")

adult_cols = [c for pair in adult_groups for c in pair]
senior_cols = [c for pair in senior_groups for c in pair]

df03["adult20_50_total"] = df03[adult_cols].sum(axis=1, min_count=1)
df03["senior60_total"] = df03[senior_cols].sum(axis=1, min_count=1)

df03["adult20_50_masked_groups"] = sum((df03[m].isna() & df03[w].isna()) for m, w in adult_groups).astype(int)
df03["senior60_masked_groups"] = sum((df03[m].isna() & df03[w].isna()) for m, w in senior_groups).astype(int)

z03 = (
    df03.groupby("gid", as_index=False)
       .agg(
           adult20_50_total=("adult20_50_total", lambda s: s.sum(min_count=1)),
           adult20_50_masked_groups=("adult20_50_masked_groups", "max"),
           senior60_total=("senior60_total", lambda s: s.sum(min_count=1)),
           senior60_masked_groups=("senior60_masked_groups", "max"),
       )
)

new_cols = [
    "child0_15_total",
    "adult20_50_total", "adult20_50_masked_groups",
    "senior60_total", "senior60_masked_groups",
]
grid_master = grid_master.drop(columns=new_cols + ["masked_cnt_03"], errors="ignore")
grid_master = grid_master.merge(z_child, on="gid", how="left")
grid_master = grid_master.merge(z03, on="gid", how="left")

# 맨 뒤로 배치
tail = [c for c in new_cols if c in grid_master.columns]
rest = [c for c in grid_master.columns if c not in tail]
grid_master = grid_master[rest + tail]


# =========================
# 4) 04 유동인구 (20~50/60+) -> gid 매핑(청크 내 유니크좌표 sjoin) -> gid별 mean -> grid_master merge
# =========================
def build_04_chunked(path04, grid_slim, chunksize=200_000):
    usecols = [
        "lon","lat",
        "m_20g_pop","m_30g_pop","m_40g_pop","m_50g_pop","m_60g_pop",
        "w_20g_pop","w_30g_pop","w_40g_pop","w_50g_pop","w_60g_pop",
    ]
    adult_cols = ["m_20g_pop","w_20g_pop","m_30g_pop","w_30g_pop","m_40g_pop","w_40g_pop","m_50g_pop","w_50g_pop"]
    senior_cols = ["m_60g_pop","w_60g_pop"]

    sum_20_50, cnt_20_50 = {}, {}
    sum_60p, cnt_60p = {}, {}

    for chunk in pd.read_csv(path04, usecols=usecols, chunksize=chunksize):
        lon_s = chunk["lon"].astype(str).str.strip()
        lat_s = chunk["lat"].astype(str).str.strip()
        lon = pd.to_numeric(lon_s, errors="coerce")
        lat = pd.to_numeric(lat_s, errors="coerce")
        m = lon.notna() & lat.notna()

        chunk = chunk.loc[m].copy()
        chunk["lon_s"] = lon_s.loc[m].values
        chunk["lat_s"] = lat_s.loc[m].values
        chunk["lon"] = lon.loc[m].values
        chunk["lat"] = lat.loc[m].values

        for c in adult_cols + senior_cols:
            chunk[c] = pd.to_numeric(chunk[c], errors="coerce").fillna(0)

        chunk["flow20_50"] = chunk[adult_cols].sum(axis=1)
        chunk["flow60p"] = chunk[senior_cols].sum(axis=1)

        chunk = _chunk_map_gid(chunk, grid_slim).dropna(subset=["gid"])

        gsum = chunk.groupby("gid")[["flow20_50","flow60p"]].sum()
        gcnt = chunk.groupby("gid").size()

        for gid, row in gsum.iterrows():
            sum_20_50[gid] = sum_20_50.get(gid, 0.0) + float(row["flow20_50"])
            sum_60p[gid] = sum_60p.get(gid, 0.0) + float(row["flow60p"])
        for gid, c in gcnt.items():
            cnt_20_50[gid] = cnt_20_50.get(gid, 0) + int(c)
            cnt_60p[gid] = cnt_60p.get(gid, 0) + int(c)

    gids = list(sum_20_50.keys())
    return pd.DataFrame({
        "gid": gids,
        "flow20_50_mean": [sum_20_50[g] / cnt_20_50[g] for g in gids],
        "flow60p_mean": [sum_60p[g] / cnt_60p[g] for g in gids],
    })

z04 = build_04_chunked("04._성연령별_유동인구.csv", grid_slim, chunksize=200_000)
cols04 = ["flow20_50_mean", "flow60p_mean"]
grid_master = grid_master.drop(columns=cols04, errors="ignore").merge(z04, on="gid", how="left")
