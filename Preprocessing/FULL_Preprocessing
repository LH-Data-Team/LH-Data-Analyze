"""
build_link_master_ts.py

[목표] v_link_id(방향 포함) + timeslot 기반 link_master_ts 생성

[전처리/결합 개요]
- (08) 상세도로망(level6) geojson:
    - up_v_link / dw_v_link를 "행으로 펼쳐" v_link_id 기준 link_master_base 생성
- (09) 평균속도:
    - timeslot 소수점 제거(Int) 후 v_link_id + timeslot로 집계(df09_ts)
- (10) 추정교통량:
    - timeslot 소수점 제거(Int) 후 v_link_id + timeslot로 집계(df10_ts)
    - AADT 4개는 반올림 후 Int64(소수점 제거)
- (09+10) timeslot 합집합(ts_union) 만들고,
    - link_master_base와 v_link_id로 inner join해서 (v_link_id, timeslot) 조합만 생성
    - 그 후 09/10을 (v_link_id,timeslot)로 left merge
- (11/12) 혼잡강도:
    - timeslot 없음 → v_link_id로만 left merge (모든 timeslot 행에 복제됨)
"""

import pandas as pd
import geopandas as gpd

# =========================
# 08) 상세도로망 -> link_master_base (v_link_id 기준, UP/DW를 행으로 펼침)
# =========================
g08 = gpd.read_file("08.상세도로망_네트워크.geojson")

use_cols_08 = [
    "link_id",
    "up_f_node","up_t_node","dw_f_node","dw_t_node",
    "max_speed","road_name","road_no","road_rank","link_type",
    "pavement","road_type",
    "up_lanes","dw_lanes","lanes","oneway","length","level",
    "up_v_link","dw_v_link",
    "lon","lat"
]
keep_08 = [c for c in use_cols_08 if c in g08.columns]
df08 = pd.DataFrame(g08[keep_08]).copy()

up = df08.copy()
up["dir"] = "UP"
up["v_link_id"] = up["up_v_link"]
up["f_node"] = up["up_f_node"]
up["t_node"] = up["up_t_node"]
up["lanes_dir"] = up["up_lanes"]

dw = df08.copy()
dw["dir"] = "DW"
dw["v_link_id"] = dw["dw_v_link"]
dw["f_node"] = dw["dw_f_node"]
dw["t_node"] = dw["dw_t_node"]
dw["lanes_dir"] = dw["dw_lanes"]

link_master_base = pd.concat([up, dw], ignore_index=True)

drop_cols = [c for c in ["up_f_node","up_t_node","dw_f_node","dw_t_node","up_lanes","dw_lanes","up_v_link","dw_v_link"] if c in link_master_base.columns]
link_master_base = link_master_base.drop(columns=drop_cols, errors="ignore")
link_master_base = link_master_base.dropna(subset=["v_link_id"]).copy()

# v_link_id 타입 통일 (".0" 제거)
link_master_base["v_link_id"] = link_master_base["v_link_id"].astype(str).str.replace(r"\.0$", "", regex=True)

front = ["v_link_id","link_id","dir","f_node","t_node"]
link_master_base = link_master_base[front + [c for c in link_master_base.columns if c not in front]]

# =========================
# 09) 평균속도 -> df09_ts (v_link_id + timeslot)
# =========================
df09 = pd.read_csv("09._평균속도.csv", dtype={"v_link_id": str})
df09 = df09[["v_link_id","timeslot","velocity_AVRG","probe"]].copy()

df09["v_link_id"] = df09["v_link_id"].astype(str).str.replace(r"\.0$", "", regex=True)
df09["velocity_AVRG"] = pd.to_numeric(df09["velocity_AVRG"], errors="coerce")
df09["probe"] = pd.to_numeric(df09["probe"], errors="coerce").fillna(0)

ts09 = df09["timeslot"].astype(str).str.extract(r"(\d+)")[0]
df09["timeslot"] = pd.to_numeric(ts09, errors="coerce").astype("Int64")

df09_ts = (
    df09.groupby(["v_link_id","timeslot"], as_index=False)
        .agg(
            velocity_AVRG=("velocity_AVRG", "mean"),
            probe=("probe", "sum"),
        )
)

# =========================
# 10) 추정교통량 -> df10_ts (v_link_id + timeslot) + 소수점 제거
# =========================
df10 = pd.read_csv("10._추정교통량.csv", dtype={"v_link_id": str})
df10 = df10[["v_link_id","timeslot","ALL_AADT","PSCR_AADT","BUS_AADT","FGCR_AADT"]].copy()

df10["v_link_id"] = df10["v_link_id"].astype(str).str.replace(r"\.0$", "", regex=True)

ts10 = df10["timeslot"].astype(str).str.extract(r"(\d+)")[0]
df10["timeslot"] = pd.to_numeric(ts10, errors="coerce").astype("Int64")

for c in ["ALL_AADT","PSCR_AADT","BUS_AADT","FGCR_AADT"]:
    df10[c] = pd.to_numeric(df10[c], errors="coerce")

df10_ts = (
    df10.groupby(["v_link_id","timeslot"], as_index=False)
        .agg(
            ALL_AADT=("ALL_AADT","mean"),
            PSCR_AADT=("PSCR_AADT","mean"),
            BUS_AADT=("BUS_AADT","mean"),
            FGCR_AADT=("FGCR_AADT","mean"),
        )
)
for c in ["ALL_AADT","PSCR_AADT","BUS_AADT","FGCR_AADT"]:
    df10_ts[c] = df10_ts[c].round().astype("Int64")

# =========================
# 09+10) timeslot 합집합 -> link_master_ts 생성 후 09/10 붙이기
# =========================
ts_union = pd.concat(
    [df09_ts[["v_link_id","timeslot"]], df10_ts[["v_link_id","timeslot"]]],
    ignore_index=True
).drop_duplicates()

# (v_link_id, timeslot) 조합이 실제로 존재하는 행만 생성
link_master_ts = link_master_base.merge(ts_union, on="v_link_id", how="inner")

link_master_ts = link_master_ts.merge(df09_ts, on=["v_link_id","timeslot"], how="left")
link_master_ts = link_master_ts.merge(df10_ts, on=["v_link_id","timeslot"], how="left")

# =========================
# 11/12) 혼잡강도 (timeslot 없음) -> v_link_id로만 붙이기
# =========================
df11 = pd.read_csv("11._혼잡빈도강도.csv", dtype={"v_link_id": str})
df11 = df11[["v_link_id","FRIN_CG"]].copy()
df11["v_link_id"] = df11["v_link_id"].astype(str).str.replace(r"\.0$", "", regex=True)
df11["FRIN_CG"] = pd.to_numeric(df11["FRIN_CG"], errors="coerce")
df11_1 = df11.groupby("v_link_id", as_index=False).agg(FRIN_CG=("FRIN_CG","mean"))

df12 = pd.read_csv("12._혼잡시간강도.csv", dtype={"v_link_id": str})
df12 = df12[["v_link_id","TI_CG"]].copy()
df12["v_link_id"] = df12["v_link_id"].astype(str).str.replace(r"\.0$", "", regex=True)
df12["TI_CG"] = pd.to_numeric(df12["TI_CG"], errors="coerce")
df12_1 = df12.groupby("v_link_id", as_index=False).agg(TI_CG=("TI_CG","mean"))

link_master_ts = link_master_ts.drop(columns=["FRIN_CG","TI_CG"], errors="ignore")
link_master_ts = link_master_ts.merge(df11_1, on="v_link_id", how="left")
link_master_ts = link_master_ts.merge(df12_1, on="v_link_id", how="left")
