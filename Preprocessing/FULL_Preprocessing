# -*- coding: utf-8 -*-
"""
build_grid_master.py

[목표] 100m 격자(gid) 기반 grid_master 생성

[전처리/결합 개요]
- (01+02) 격자(폴리곤) 로드 → gid, gbn, geometry 표준화(EPSG:4326) → grid_master(=gid 뼈대) 생성
- (03) 거주인구(격자) : 20~50 / 60+ 합계 + masked(연령대 그룹 기준) 생성 후 gid로 결합
- (아동 CSV) : SGIS에서 수집된 gid별 0~15(pop) → child0_15_total로 결합(결측 NaN 유지)
- (04) 유동인구 : lon/lat → gid 매핑 후 20~50, 60+만 합쳐서 gid 연간 대표(mean) 생성
- (05/06) 대용량 TMST(00~23) : 청크+청크 내 유니크좌표만 sjoin → gid별 sum/count 누적 → mean
- (07) 대용량 서비스인구(H/W) : 청크+청크 내 유니크좌표만 sjoin → (gid,hw)별 sum/count → mean → wide 4컬럼
- (13/14/16/17/18/20/21) 상대적으로 소용량 : lon/lat 또는 geojson → gid 매핑 → gid별 집계 → grid_master merge

[결측 처리 원칙]
- 사고/시설 “개수/합” 계열은 0 채움 (없으면 0이 자연스러움)
- 07/05/06/04 등 노출 지표는 NaN 유지 (데이터 없음 vs 값 0 구분)
- 아동(child0_15_total)도 NaN 유지
- 방지턱 높이(mean)는 0/0.1을 미상으로 보고 NaN 처리(평균 계산 제외)
"""

import pandas as pd
import geopandas as gpd


# =========================
# 1+2) 격자 로드 (01+02) -> grid, grid_master, grid_slim
# =========================
grid1 = gpd.read_file("01._격자_(4개_시·구).geojson")
grid2 = gpd.read_file("02._격자_(하남교산).geojson")

grid = gpd.GeoDataFrame(pd.concat([grid1, grid2], ignore_index=True))
grid = grid.set_crs(epsg=4326, allow_override=True)
grid = grid[["gid", "gbn", "geometry"]].copy()

grid_master = grid[["gid", "gbn"]].drop_duplicates().copy()
grid_slim = grid[["gid", "geometry"]].copy()  # 대용량 매핑용


# =========================
# 공통: 청크 내 유니크좌표만 sjoin 해서 gid 붙이기
# =========================
def _chunk_map_gid(df: pd.DataFrame, grid_slim: gpd.GeoDataFrame) -> pd.DataFrame:
    """
    df에 lon_s/lat_s(문자키), lon/lat(숫자) 있어야 함.
    청크 내 유니크 좌표만 sjoin하고, df에 gid를 merge로 붙임.
    """
    uniq = df[["lon_s", "lat_s", "lon", "lat"]].drop_duplicates()
    gk = gpd.GeoDataFrame(uniq, geometry=gpd.points_from_xy(uniq["lon"], uniq["lat"]), crs="EPSG:4326")
    jk = gpd.sjoin(gk, grid_slim, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")
    map_df = jk[["lon_s", "lat_s", "gid"]]
    return df.merge(map_df, on=["lon_s", "lat_s"], how="left")


def _tmst_cols(path: str):
    cols = pd.read_csv(path, nrows=0).columns.tolist()
    return sorted([c for c in cols if c.startswith("TMST_")])


# =========================
# 13) 교통사고(geojson) -> gid 매핑 -> gid 집계 -> grid_master merge
# =========================
g13 = gpd.read_file("13._교통사고이력.geojson")
if g13.crs is None:
    g13 = g13.set_crs(epsg=4326, allow_override=True)
else:
    g13 = g13.to_crs(epsg=4326)

joined13 = gpd.sjoin(g13, grid, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")
acc = joined13.dropna(subset=["gid"]).copy()

# (선택) 범주 결측은 "미상" 처리
for c in ["victim_vhcle", "injury_svrity", "age_group"]:
    if c in acc.columns:
        acc[c] = acc[c].fillna("미상")

acc_grid = (
    acc.groupby(["gid", "gbn"], as_index=False)
       .agg(
           acc_cnt=("gid", "size"),
           dprs_cnt=("dprs_cnt", "sum"),
           sep_cnt=("sep_cnt", "sum"),
           slp_cnt=("slp_cnt", "sum"),
           inj_aplcnt_cnt=("inj_aplcnt_cnt", "sum"),
       )
)

cols13 = ["acc_cnt", "dprs_cnt", "sep_cnt", "slp_cnt", "inj_aplcnt_cnt"]
grid_master = grid_master.drop(columns=cols13, errors="ignore").merge(
    acc_grid[["gid"] + cols13],
    on="gid",
    how="left",
)
for c in cols13:
    grid_master[c] = grid_master[c].fillna(0).astype(int)


# =========================
# 18) 횡단보도 -> gid 매핑 -> gid별 개수 -> grid_master merge
# =========================
df18 = pd.read_csv("18._횡단보도_위치정보.csv")
df18["lon"] = pd.to_numeric(df18["lon"], errors="coerce")
df18["lat"] = pd.to_numeric(df18["lat"], errors="coerce")
df18 = df18.dropna(subset=["lon", "lat"]).copy()

g18 = gpd.GeoDataFrame(df18, geometry=gpd.points_from_xy(df18["lon"], df18["lat"]), crs="EPSG:4326")
j18 = gpd.sjoin(g18, grid_slim, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")

z18 = (
    j18.dropna(subset=["gid"])
       .groupby("gid", as_index=False)
       .size()
       .rename(columns={"size": "crosswalk_cnt"})
)

grid_master = grid_master.drop(columns=["crosswalk_cnt"], errors="ignore").merge(z18, on="gid", how="left")
grid_master["crosswalk_cnt"] = grid_master["crosswalk_cnt"].fillna(0).astype(int)


# =========================
# 14) 어린이보호구역 -> gid 매핑 -> fac_nm_nunique -> grid_master merge
# =========================
df14 = pd.read_csv("14._어린이보호구역.csv")
df14["lon"] = pd.to_numeric(df14["lon"], errors="coerce")
df14["lat"] = pd.to_numeric(df14["lat"], errors="coerce")
df14 = df14.dropna(subset=["lon", "lat"]).copy()

g14 = gpd.GeoDataFrame(df14, geometry=gpd.points_from_xy(df14["lon"], df14["lat"]), crs="EPSG:4326")
j14 = gpd.sjoin(g14, grid_slim, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")

z14 = (
    j14.dropna(subset=["gid"])
       .groupby("gid", as_index=False)
       .agg(fac_nm_nunique=("fac_nm", "nunique"))
)

grid_master = grid_master.drop(columns=["fac_nm_nunique"], errors="ignore").merge(z14, on="gid", how="left")
grid_master["fac_nm_nunique"] = grid_master["fac_nm_nunique"].fillna(0).astype(int)


# =========================
# 16) 유치원 -> gid 매핑 -> (age3+age4+age5+mix+spec) 합 -> gid 합 -> kinder_child_cnt
# =========================
df16 = pd.read_csv("16._유치원현황.csv")
df16["lon"] = pd.to_numeric(df16["lon"], errors="coerce")
df16["lat"] = pd.to_numeric(df16["lat"], errors="coerce")
df16 = df16.dropna(subset=["lon", "lat"]).copy()

cnt_cols = ["age3_cnt", "age4_cnt", "age5_cnt", "mix_cnt", "spec_cnt"]
for c in cnt_cols:
    df16[c] = pd.to_numeric(df16[c], errors="coerce").fillna(0)

df16["kinder_child_cnt"] = df16[cnt_cols].sum(axis=1)

g16 = gpd.GeoDataFrame(df16, geometry=gpd.points_from_xy(df16["lon"], df16["lat"]), crs="EPSG:4326")
j16 = gpd.sjoin(g16, grid_slim, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")

z16 = (
    j16.dropna(subset=["gid"])
       .groupby("gid", as_index=False)
       .agg(kinder_child_cnt=("kinder_child_cnt", "sum"))
)

grid_master = grid_master.drop(columns=["kinder_child_cnt"], errors="ignore").merge(z16, on="gid", how="left")
grid_master["kinder_child_cnt"] = pd.to_numeric(grid_master["kinder_child_cnt"], errors="coerce").fillna(0).astype(int)


# =========================
# 17) 어린이집 -> gid 매핑 -> curr_cnt gid 합 -> kinder_child_cnt에 더해서 덮어쓰기
# =========================
df17 = pd.read_csv("17._어린이집현황.csv")
df17["lon"] = pd.to_numeric(df17["lon"], errors="coerce")
df17["lat"] = pd.to_numeric(df17["lat"], errors="coerce")
df17 = df17.dropna(subset=["lon", "lat"]).copy()
df17["curr_cnt"] = pd.to_numeric(df17["curr_cnt"], errors="coerce").fillna(0)

g17 = gpd.GeoDataFrame(df17, geometry=gpd.points_from_xy(df17["lon"], df17["lat"]), crs="EPSG:4326")
j17 = gpd.sjoin(g17, grid_slim, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")

z17 = (
    j17.dropna(subset=["gid"])
       .groupby("gid", as_index=False)
       .agg(curr_cnt_sum=("curr_cnt", "sum"))
)

grid_master = grid_master.drop(columns=["curr_cnt_sum"], errors="ignore").merge(z17, on="gid", how="left")
grid_master["curr_cnt_sum"] = pd.to_numeric(grid_master["curr_cnt_sum"], errors="coerce").fillna(0)
grid_master["kinder_child_cnt"] = (grid_master["kinder_child_cnt"] + grid_master["curr_cnt_sum"]).astype(int)
grid_master = grid_master.drop(columns=["curr_cnt_sum"])


# =========================
# 20) CCTV -> gid 매핑 -> cam_cnt gid 합 -> grid_master merge
# =========================
df20 = pd.read_csv("20._CCTV_현황.csv")
df20["lon"] = pd.to_numeric(df20["lon"], errors="coerce")
df20["lat"] = pd.to_numeric(df20["lat"], errors="coerce")
df20 = df20.dropna(subset=["lon", "lat"]).copy()
df20["cam_cnt"] = pd.to_numeric(df20["cam_cnt"], errors="coerce").fillna(0)

g20 = gpd.GeoDataFrame(df20, geometry=gpd.points_from_xy(df20["lon"], df20["lat"]), crs="EPSG:4326")
j20 = gpd.sjoin(g20, grid_slim, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")

z20 = (
    j20.dropna(subset=["gid"])
       .groupby("gid", as_index=False)
       .agg(cam_cnt=("cam_cnt", "sum"))
)

grid_master = grid_master.drop(columns=["cam_cnt"], errors="ignore").merge(z20, on="gid", how="left")
grid_master["cam_cnt"] = grid_master["cam_cnt"].fillna(0).astype(int)


# =========================
# 21) 과속방지턱 -> gid 매핑 -> 4개(평균/비율)만 -> grid_master merge
#     - fac_hght: 0, 0.1은 NaN 처리(평균 제외)
#     - sprtn/cntns: Y=1 else 0 -> mean=비율
# =========================
df21 = pd.read_csv("21._과속방지턱_현황.csv")
df21["lon"] = pd.to_numeric(df21["lon"], errors="coerce")
df21["lat"] = pd.to_numeric(df21["lat"], errors="coerce")
df21 = df21.dropna(subset=["lon", "lat"]).copy()

df21["fac_hght"] = pd.to_numeric(df21["fac_hght"], errors="coerce")
df21["fac_wdth"] = pd.to_numeric(df21["fac_wdth"], errors="coerce")
df21.loc[df21["fac_hght"].isin([0, 0.1]), "fac_hght"] = pd.NA

def to01_yn(series):
    s = series.astype(str).str.strip().str.upper()
    out = s.map({"Y": 1, "N": 0})
    return out.fillna(0).astype(int)

df21["sprtn_01"] = to01_yn(df21["sprtn"])
df21["cntns_01"] = to01_yn(df21["cntns"])

g21 = gpd.GeoDataFrame(df21, geometry=gpd.points_from_xy(df21["lon"], df21["lat"]), crs="EPSG:4326")
j21 = gpd.sjoin(g21, grid_slim, how="left", predicate="within").drop(columns=["index_right"], errors="ignore")

z21 = (
    j21.dropna(subset=["gid"])
       .groupby("gid", as_index=False)
       .agg(
           speedbump_hght_mean=("fac_hght", "mean"),
           speedbump_wdth_mean=("fac_wdth", "mean"),
           speedbump_sprtn_ratio=("sprtn_01", "mean"),
           speedbump_cntns_ratio=("cntns_01", "mean"),
       )
)
z21["speedbump_wdth_mean"] = z21["speedbump_wdth_mean"].round(2)

cols21 = ["speedbump_hght_mean", "speedbump_wdth_mean", "speedbump_sprtn_ratio", "speedbump_cntns_ratio"]
grid_master = grid_master.drop(columns=cols21, errors="ignore").merge(z21, on="gid", how="left")

# 폭/비율은 0 채움, 높이는 NaN 유지
grid_master["speedbump_wdth_mean"] = grid_master["speedbump_wdth_mean"].fillna(0)
grid_master["speedbump_sprtn_ratio"] = grid_master["speedbump_sprtn_ratio"].fillna(0)
grid_master["speedbump_cntns_ratio"] = grid_master["speedbump_cntns_ratio"].fillna(0)


# =========================
# 7) 대용량 07(서비스인구) : 청크+유니크좌표 sjoin -> (gid,hw) sum/count -> mean -> wide 4컬럼
# =========================
def build_07_chunked(path07, grid_slim, chunksize=200_000):
    acc_hw = {}  # (gid, hw) -> [sum_w, sum_v, cnt]
    usecols = ["lon", "lat", "hw", "w_pop", "v_pop"]

    for chunk in pd.read_csv(path07, usecols=usecols, chunksize=chunksize):
        lon_s = chunk["lon"].astype(str).str.strip()
        lat_s = chunk["lat"].astype(str).str.strip()
        lon = pd.to_numeric(lon_s, errors="coerce")
        lat = pd.to_numeric(lat_s, errors="coerce")
        m = lon.notna() & lat.notna()

        chunk = chunk.loc[m].copy()
        chunk["lon_s"] = lon_s.loc[m].values
        chunk["lat_s"] = lat_s.loc[m].values
        chunk["lon"] = lon.loc[m].values
        chunk["lat"] = lat.loc[m].values

        chunk["hw"] = chunk["hw"].astype(str).str.strip().str.upper()
        chunk["w_pop"] = pd.to_numeric(chunk["w_pop"].astype(str).str.replace(",", ""), errors="coerce")
        chunk["v_pop"] = pd.to_numeric(chunk["v_pop"].astype(str).str.replace(",", ""), errors="coerce")

        chunk = _chunk_map_gid(chunk, grid_slim).dropna(subset=["gid"])

        grp = (
            chunk.groupby(["gid", "hw"], as_index=False)
                 .agg(sum_w=("w_pop", "sum"), sum_v=("v_pop", "sum"), cnt=("w_pop", "size"))
        )

        for r in grp.itertuples(index=False):
            k = (r.gid, r.hw)
            if k not in acc_hw:
                acc_hw[k] = [0.0, 0.0, 0]
            acc_hw[k][0] += 0.0 if pd.isna(r.sum_w) else float(r.sum_w)
            acc_hw[k][1] += 0.0 if pd.isna(r.sum_v) else float(r.sum_v)
            acc_hw[k][2] += int(r.cnt)

    rows = []
    for (gid, hw), (sw, sv, c) in acc_hw.items():
        if c > 0:
            rows.append({"gid": gid, "hw": hw, "w_pop_mean": sw / c, "v_pop_mean": sv / c})

    z07 = pd.DataFrame(rows)
    wide07 = z07.pivot(index="gid", columns="hw", values=["w_pop_mean", "v_pop_mean"]).reset_index()
    wide07.columns = [
        "gid" if c == ("gid", "") or c == "gid" else
        ("w_pop_weekday_mean" if c == ("w_pop_mean", "H") else
         "w_pop_weekend_mean" if c == ("w_pop_mean", "W") else
         "v_pop_weekday_mean" if c == ("v_pop_mean", "H") else
         "v_pop_weekend_mean" if c == ("v_pop_mean", "W") else str(c))
        for c in wide07.columns
    ]
    return wide07

wide07 = build_07_chunked("07._주중주말_서비스인구.csv", grid_slim, chunksize=200_000)
cols07 = ["w_pop_weekday_mean", "w_pop_weekend_mean", "v_pop_weekday_mean", "v_pop_weekend_mean"]
grid_master = grid_master.drop(columns=cols07, errors="ignore").merge(
    wide07[["gid"] + [c for c in cols07 if c in wide07.columns]],
    on="gid",
    how="left",
)
# NaN 유지(미관측 vs 0 구분)


# =========================
# 6) 대용량 06(방문인구 TMST) : 청크+유니크좌표 sjoin -> gid별 sum/count -> mean
# =========================
def build_06_chunked(path06, grid_slim, chunksize=100_000):
    tmst = _tmst_cols(path06)
    usecols = ["lon", "lat"] + tmst

    sum_cols = ["visit_total", "visit_am", "visit_pm", "visit_ev", "visit_night"]
    acc_sum = {}  # gid -> Series sums
    acc_cnt = {}  # gid -> int count

    def cols_range(a, b):
        want = [f"TMST_{h:02d}" for h in range(a, b+1)]
        return [c for c in want if c in tmst]

    for chunk in pd.read_csv(path06, usecols=usecols, chunksize=chunksize):
        lon_s = chunk["lon"].astype(str).str.strip()
        lat_s = chunk["lat"].astype(str).str.strip()
        lon = pd.to_numeric(lon_s, errors="coerce")
        lat = pd.to_numeric(lat_s, errors="coerce")
        m = lon.notna() & lat.notna()

        chunk = chunk.loc[m].copy()
        chunk["lon_s"] = lon_s.loc[m].values
        chunk["lat_s"] = lat_s.loc[m].values
        chunk["lon"] = lon.loc[m].values
        chunk["lat"] = lat.loc[m].values

        for c in tmst:
            chunk[c] = pd.to_numeric(chunk[c].astype(str).str.replace(",", ""), errors="coerce").fillna(0)

        chunk["visit_total"] = chunk[tmst].sum(axis=1)
        chunk["visit_am"] = chunk[cols_range(7, 9)].sum(axis=1)
        chunk["visit_pm"] = chunk[cols_range(14, 16)].sum(axis=1)
        chunk["visit_ev"] = chunk[cols_range(17, 19)].sum(axis=1)
        chunk["visit_night"] = chunk[cols_range(20, 23)].sum(axis=1)

        chunk = _chunk_map_gid(chunk, grid_slim).dropna(subset=["gid"])

        grp_sum = chunk.groupby("gid")[sum_cols].sum()
        grp_cnt = chunk.groupby("gid").size()

        for gid, row in grp_sum.iterrows():
            if gid not in acc_sum:
                acc_sum[gid] = row.copy()
            else:
                acc_sum[gid] = acc_sum[gid].add(row, fill_value=0)

        for gid, c in grp_cnt.items():
            acc_cnt[gid] = acc_cnt.get(gid, 0) + int(c)

    z06 = pd.DataFrame([{"gid": gid, **(acc_sum[gid] / acc_cnt[gid]).to_dict()} for gid in acc_sum.keys()])
    z06 = z06.rename(columns={
        "visit_total": "visit_total_mean",
        "visit_am": "visit_am_mean",
        "visit_pm": "visit_pm_mean",
        "visit_ev": "visit_ev_mean",
        "visit_night": "visit_night_mean",
    })
    return z06

z06 = build_06_chunked("06._시간대별_방문인구.csv", grid_slim, chunksize=100_000)
cols06 = ["visit_total_mean", "visit_am_mean", "visit_pm_mean", "visit_ev_mean", "visit_night_mean"]
grid_master = grid_master.drop(columns=cols06, errors="ignore").merge(z06[["gid"] + cols06], on="gid", how="left")
# NaN 유지


# =========================
